# ─────────────────────────────────────────────────────────
# BOTDASHBOARD — environment variables
# Copy this to `.env` for local dev; set on Vercel dashboard for prod.
# NEVER COMMIT the filled-in .env file.
# ─────────────────────────────────────────────────────────

# ── Supabase (https://app.supabase.com → Settings → API) ──
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJhbG...        # service_role key — bypasses RLS, server-only

# ── Session signing ──
# Generate once with:  python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=CHANGE_ME_64_HEX_CHARS

# ── Admin bootstrap (one-time, optional) ──
# If set, the /api/bootstrap endpoint will create this admin user
# on first run. Remove after first login.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

# ── CORS (optional, leave empty for same-origin) ──
ALLOWED_ORIGINS=
